{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rixoslounge",
  "compatibility_date": "2026-04-18",
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "rixoslounge"
    }
  ]
}